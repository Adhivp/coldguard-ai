# ──────────────────────────────────────────────────────────────────────────────
# ColdGuard Backend – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase project URL (from Supabase dashboard → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service-role key (NOT the anon/public key — this bypasses RLS)
# Dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ──────────────────────────────────────────────────────────────────────────────
# Telemetry ingestion rules
# ──────────────────────────────────────────────────────────────────────────────

# Maximum seconds a reading's UTC timestamp may differ from server time
# before the request is rejected as stale/replayed (default: 70s)
TIMESTAMP_TOLERANCE_SECONDS=70

# Cool-off window in seconds after the last accepted reading per device.
# During this window the most recent stored reading is returned instead of
# accepting a new one. Arduino sends every 60 s; cool-off is 300 s (5 min).
COOLOFF_WINDOW_SECONDS=300

# Maximum allowed gap (seconds) between two consecutive readings before the
# continuity check flags the sequence as broken (default: 70s — allows one
# 60 s interval plus 10 s jitter).
MAX_GAP_SECONDS=70

# ──────────────────────────────────────────────────────────────────────────────
# Device provisioning
# ──────────────────────────────────────────────────────────────────────────────

# These are managed in the Supabase `devices` table, not here.
# Use the /admin/provision endpoint (restricted) to register a new device and
# receive its 256-bit secret. Store the secret only on the device itself.
